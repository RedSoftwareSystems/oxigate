# .env.example — OAuth2 / OIDC credentials for the Oxigate example
#
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to source control — it contains secrets.
# .env is listed in the repo .gitignore.

# ── OIDC provider ─────────────────────────────────────────────────────────────
# Issuer URL used for OIDC auto-discovery.
# The gateway fetches <OAUTH_ISSUER>/.well-known/openid-configuration
# to resolve the authorization and token endpoints automatically.
#
# Google (no further endpoint configuration needed):
OAUTH_ISSUER=https://accounts.google.com

# ── OAuth2 client credentials ─────────────────────────────────────────────────
# Create a Web Application credential at:
#   https://console.developers.google.com/apis/credentials
#
# Add the following Authorised Redirect URI:
#   http://localhost:8080/auth/callback
#
OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-google-client-secret

# ── Session cookie encryption key ─────────────────────────────────────────────
# Must be at least 32 characters long.
# Generate a strong random value with:
#   openssl rand -base64 48
COOKIE_ENCRYPTION_KEY=change-me-to-a-random-string-at-least-32-chars!!

# ── API key forwarded to the backend ──────────────────────────────────────────
API_KEY=example-api-key-change-in-production
